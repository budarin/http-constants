{
    "name": "@budarin/http-constants",
    "version": "1.0.17",
    "description": "Http constants",
    "keywords": [
        "http",
        "constants"
    ],
    "author": "Vadim Budarin",
    "license": "MIT",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist/"
    ],
    "devDependencies": {
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    },
    "scripts": {
        "build": "tsc",
        "type-check": "tsc --noEmit",
        "pnpm-install": "pnpm install",
        "upgrade-dependencies": "pnpm upgrade -i",
        "publish-package": "pnpm build && pnpm publish --access=public"
    },
    "packageManager": "pnpm@10.16.1"
}
